GATEWAY_PUBLIC_URL=https://gateway.example.com
GATEWAY_SIGNING_SECRET=replace-with-at-least-32-random-bytes
GATEWAY_ADMIN_TOKEN=replace-with-admin-token
GATEWAY_STORE_PATH=./data/gateway-store.json

